{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start local preview on 5179",
      "type": "shell",
      "command": "PORT=5179 /Users/kukudejie/.cache/codex-runtimes/codex-primary-runtime/dependencies/node/bin/node server.js",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Local Media Saver is running",
          "endsPattern": "Local Media Saver is running"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}/jesper-project"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
