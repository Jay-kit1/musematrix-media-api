      "options": {
        "cwd": "${workspaceFolder}/jesper-project"
      },
      "problemMatcher": []
    },
    {
      "label": "Run UX copy audit",
      "type": "shell",
      "command": "/Users/kukudejie/.cache/codex-runtimes/codex-primary-runtime/dependencies/node/bin/node tools/audit.mjs",
      "options": {
        "cwd": "${workspaceFolder}/jesper-project"
      },
      "problemMatcher": []
    }
  ]
